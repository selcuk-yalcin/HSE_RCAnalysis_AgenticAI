# HSE Root Cause Investigation System - Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenAI Configuration
# ============================================================================
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Model to use (gpt-4, gpt-4-turbo, gpt-4o-mini, gpt-3.5-turbo)
OPENAI_MODEL=gpt-4o-mini

# Temperature (0.0 = deterministic, 2.0 = very creative)
OPENAI_TEMPERATURE=0.7

# ============================================================================
# API Configuration
# ============================================================================
# Port for local development
PORT=8000

# Environment (development, staging, production)
ENVIRONMENT=development

# API Base URL (for production)
API_BASE_URL=http://localhost:8000

# ============================================================================
# Admin Panel Configuration
# ============================================================================
# Admin panel URL (Vercel deployment)
ADMIN_PANEL_URL=https://inferaworld-admin.vercel.app

# ============================================================================
# Database Configuration (Optional - for future use)
# ============================================================================
# DATABASE_URL=postgresql://user:password@localhost:5432/hse_db
# DATABASE_URL=sqlite:///./hse_database.db

# ============================================================================
# Security (Optional)
# ============================================================================
# SECRET_KEY=your-secret-key-for-jwt
# API_KEY=your-api-key-for-authentication

# ============================================================================
# Logging
# ============================================================================
LOG_LEVEL=INFO

# ============================================================================
# Agent Timeout Settings
# ============================================================================
AGENT_TIMEOUT=30
MAX_RETRIES=3
